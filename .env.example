# ==============================================
# TGP Pokemon - Variáveis de Ambiente
# ==============================================
# Copie este arquivo para .env e preencha os valores

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# --- URLs do App ---
NEXT_PUBLIC_APP_URL=https://pokemongo-xi.vercel.app
APP_URL=https://pokemongo-xi.vercel.app

# --- Mercado Pago ---
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-seu_access_token_aqui
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=APP_USR-sua_public_key_aqui
MERCADOPAGO_WEBHOOK_SECRET=seu_webhook_secret_aqui

# --- Google OAuth (configurar no Google Cloud Console) ---
# GOOGLE_CLIENT_ID=seu_client_id_aqui.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=seu_client_secret_aqui
